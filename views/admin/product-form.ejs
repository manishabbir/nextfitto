<%- include('../partials/admin-header') %>

<div class="admin-page-header">
    <h1><%= product ? 'Edit Product' : 'Add Product' %></h1>
    <a href="/admin/products" class="btn btn-sm">← Back</a>
</div>

<div class="admin-form">
    <form action="<%= product ? '/admin/products/edit/' + product.id : '/admin/products/add' %>" method="POST" enctype="multipart/form-data">
        <div class="form-row">
            <div class="form-group">
                <label>Product Name *</label>
                <input type="text" name="name" value="<%= product ? product.name : '' %>" required />
            </div>
            <div class="form-group">
                <label>Category</label>
                <select name="category">
                    <option value="">Select Category</option>
                    <% if (categories && categories.length) { %>
                        <% categories.forEach(cat => { %>
                        <option value="<%= cat.name %>" <%= product && product.category === cat.name ? 'selected' : '' %>><%= cat.name %></option>
                        <% }); %>
                    <% } %>
                </select>
            </div>
        </div>

        <div class="form-group">
            <label>Description</label>
            <textarea name="description" rows="3"><%= product ? product.description : '' %></textarea>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Price (Rs.) *</label>
                <input type="number" step="0.01" name="price" value="<%= product ? product.price : '' %>" required />
            </div>
            <div class="form-group">
                <label>Original Price (Rs.)</label>
                <input type="number" step="0.01" name="originalPrice" value="<%= product ? product.originalPrice : '' %>" />
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Stock Quantity</label>
                <input type="number" name="stock" value="<%= product ? product.stock : 0 %>" />
            </div>
            <div class="form-group">
                <label>Badge (e.g., Sale, New, Popular)</label>
                <input type="text" name="badge" value="<%= product ? product.badge : '' %>" placeholder="e.g., Sale" />
            </div>
        </div>

        <div class="form-group">
            <label>Product Image</label>
            <% if (product && product.image) { %>
                <div class="current-image">
                    <img src="<%= product.image %>" alt="Current" style="max-width:100px;border-radius:8px;margin-bottom:10px" />
                    <input type="hidden" name="existingImage" value="<%= product.image %>" />
                </div>
            <% } %>
            <input type="file" name="image" accept="image/*" />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><%= product ? 'Update Product' : 'Add Product' %></button>
            <a href="/admin/products" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

<%- include('../partials/admin-footer') %>