<%- include('../partials/admin-header') %>

<div class="admin-page-header">
    <h1>Manage Categories</h1>
</div>

<div class="admin-form">
    <form action="/admin/categories/add" method="POST" class="inline-form">
        <input type="text" name="name" placeholder="New category name" required />
        <button type="submit" class="btn btn-primary"><i class="fas fa-plus"></i> Add Category</button>
    </form>
</div>

<div class="admin-table">
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Created</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% if (categories && categories.length) { %>
                <% categories.forEach(cat => { %>
                <tr>
                    <td>#<%= cat.id %></td>
                    <td><strong><%= cat.name %></strong></td>
                    <td><%= new Date(cat.created_at).toLocaleDateString() %></td>
                    <td>
                        <form action="/admin/categories/delete/<%= cat.id %>" method="POST" onsubmit="return confirm('Delete category "<%= cat.name %>"? Products in this category will not be deleted.')">
                            <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                        </form>
                    </td>
                </tr>
                <% }); %>
            <% } else { %>
                <tr><td colspan="4" class="empty">No categories yet</td></tr>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('../partials/admin-footer') %>