<%- include('../partials/admin-header') %>

<div class="admin-page-header">
    <h1>Manage Orders</h1>
</div>

<div class="admin-table">
    <table>
        <thead>
            <tr>
                <th>Order #</th>
                <th>Customer</th>
                <th>Phone</th>
                <th>City</th>
                <th>Items</th>
                <th>Total</th>
                <th>Status</th>
                <th>Date</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% if (orders && orders.length) { %>
                <% orders.forEach(order => { %>
                <tr>
                    <td>#<%= order.id %></td>
                    <td><%= order.customer_name %></td>
                    <td><%= order.customer_phone %></td>
                    <td><%= order.city || '-' %></td>
                    <td>
                        <% if (order.items && order.items.length) { %>
                            <%= order.items.length %> item(s)
                        <% } else { %>
                            -
                        <% } %>
                    </td>
                    <td>Rs. <%= Number(order.total || 0).toLocaleString() %></td>
                    <td><span class="status status-<%= order.status %>"><%= order.status %></span></td>
                    <td><%= new Date(order.created_at).toLocaleDateString() %></td>
                    <td>
                        <form action="/admin/orders/update-status/<%= order.id %>" method="POST" class="inline-form">
                            <select name="status">
                                <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                <option value="confirmed" <%= order.status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                                <option value="shipped" <%= order.status === 'shipped' ? 'selected' : '' %>>Shipped</option>
                                <option value="delivered" <%= order.status === 'delivered' ? 'selected' : '' %>>Delivered</option>
                                <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                            </select>
                            <button type="submit" class="btn btn-sm btn-edit"><i class="fas fa-check"></i></button>
                        </form>
                    </td>
                </tr>
                <% }); %>
            <% } else { %>
                <tr><td colspan="9" class="empty">No orders yet</td></tr>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('../partials/admin-footer') %>