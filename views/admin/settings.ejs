<%- include('../partials/admin-header') %>

<div class="admin-page-header">
    <h1>Store Settings</h1>
    <p>Customize your store name, colors, contact info, and more.</p>
</div>

<div class="admin-form">
    <form action="/admin/settings" method="POST" enctype="multipart/form-data">
        <div class="form-row">
            <div class="form-group">
                <label>Store Name *</label>
                <input type="text" name="store_name" value="<%= settings.store_name || 'Nextfit' %>" required />
            </div>
            <div class="form-group">
                <label>Tagline</label>
                <input type="text" name="tagline" value="<%= settings.tagline || 'Premium Kids Clothing' %>" />
            </div>
        </div>

        <div class="form-group">
            <label>Store Description</label>
            <textarea name="description" rows="3"><%= settings.description || '' %></textarea>
        </div>

        <div class="form-group">
            <label>About Text</label>
            <textarea name="about_text" rows="4"><%= settings.about_text || '' %></textarea>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Primary Color</label>
                <input type="color" name="primary_color" value="<%= settings.primary_color || '#FF6B6B' %>" />
            </div>
            <div class="form-group">
                <label>Secondary Color</label>
                <input type="color" name="secondary_color" value="<%= settings.secondary_color || '#4ECDC4' %>" />
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Phone</label>
                <input type="text" name="phone" value="<%= settings.phone || '' %>" />
            </div>
            <div class="form-group">
                <label>WhatsApp Number (without +)</label>
                <input type="text" name="whatsapp" value="<%= settings.whatsapp || '' %>" placeholder="923001234567" />
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" value="<%= settings.email || '' %>" />
            </div>
            <div class="form-group">
                <label>Address</label>
                <input type="text" name="address" value="<%= settings.address || '' %>" />
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Shipping Info</label>
                <input type="text" name="shipping_info" value="<%= settings.shipping_info || '' %>" />
            </div>
            <div class="form-group">
                <label>Return Policy</label>
                <input type="text" name="return_policy" value="<%= settings.return_policy || '' %>" />
            </div>
        </div>

        <div class="form-group">
            <label>Store Logo</label>
            <% if (settings.logo) { %>
                <div class="current-image">
                    <img src="<%= settings.logo %>" alt="Logo" style="max-width:120px;border-radius:8px;margin-bottom:10px" />
                </div>
                <input type="hidden" name="existingLogo" value="<%= settings.logo %>" />
            <% } %>
            <input type="file" name="logo" accept="image/*" />
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Settings</button>
        </div>
    </form>
</div>

<div class="admin-section" style="margin-top:40px">
    <div class="admin-section-header">
        <h2>Change Password</h2>
    </div>
    <div class="admin-form">
        <form action="/admin/change-password" method="POST">
            <div class="form-row">
                <div class="form-group">
                    <label>Current Password</label>
                    <input type="password" name="currentPassword" required />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>New Password</label>
                    <input type="password" name="newPassword" required minlength="6" />
                </div>
                <div class="form-group">
                    <label>Confirm New Password</label>
                    <input type="password" name="confirmPassword" required minlength="6" />
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary"><i class="fas fa-key"></i> Change Password</button>
            </div>
        </form>
    </div>
</div>

<%- include('../partials/admin-footer') %>