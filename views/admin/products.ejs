<%- include('../partials/admin-header') %>

<div class="admin-page-header">
    <h1>Manage Products</h1>
    <a href="/admin/products/add" class="btn btn-primary"><i class="fas fa-plus"></i> Add Product</a>
</div>

<div class="admin-table">
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Image</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Badge</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% if (products && products.length) { %>
                <% products.forEach(p => { %>
                <tr>
                    <td>#<%= p.id %></td>
                    <td><img src="<%= p.image || 'https://placehold.co/60x60/eee/999?text=N' %>" alt="<%= p.name %>" class="thumb" /></td>
                    <td><%= p.name %></td>
                    <td><%= p.category || '-' %></td>
                    <td>Rs. <%= Number(p.price).toLocaleString() %></td>
                    <td><%= p.stock || 0 %></td>
                    <td><% if (p.badge) { %><span class="badge-tag"><%= p.badge %></span><% } else { %>-<% } %></td>
                    <td class="actions">
                        <a href="/admin/products/edit/<%= p.id %>" class="btn btn-sm btn-edit"><i class="fas fa-edit"></i></a>
                        <form action="/admin/products/delete/<%= p.id %>" method="POST" style="display:inline" onsubmit="return confirm('Delete this product?')">
                            <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></button>
                        </form>
                    </td>
                </tr>
                <% }); %>
            <% } else { %>
                <tr><td colspan="8" class="empty">No products found. <a href="/admin/products/add">Add your first product</a></td></tr>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('../partials/admin-footer') %>