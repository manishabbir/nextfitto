# Database - Supabase (PostgreSQL)
# Get this from Supabase: Project Settings → Database → Connection string → URI
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?schema=public
DATABASE_URL="postgresql://postgres:your-supabase-password@db.xxxxx.supabase.co:5432/postgres?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Change to your Vercel domain after deployment, e.g.:
# NEXTAUTH_URL="https://nextfitt.vercel.app"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Google OAuth (Optional - for social login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe (for payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# UploadThing (for image uploads)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Resend (for transactional emails)
RESEND_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="NEXTFITT"